# PEACOCK ENGINE - Production Environment Configuration
# Copy this file to .env and fill in your actual API keys

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3099
HOST=127.0.0.1

# =============================================================================
# API KEYS - Replace with your actual keys
# Format: label1:key1,label2:key2 (comma-separated, label:prefix optional)
# =============================================================================

# Groq API Keys (get from https://console.groq.com)
# Example: GROQ_KEYS="account1:gsk_abc123,account2:gsk_def456"
GROQ_KEYS=""

# Google Gemini API Keys (get from https://aistudio.google.com/app/apikey)
# Example: GOOGLE_KEYS="main:AIzaSy...,backup:AIzaSy..."
GOOGLE_KEYS=""

# DeepSeek API Keys (get from https://platform.deepseek.com)
# Example: DEEPSEEK_KEYS="main:sk-...,backup:sk-..."
DEEPSEEK_KEYS=""

# Mistral API Keys (get from https://console.mistral.ai)
# Example: MISTRAL_KEYS="main:...,backup:..."
MISTRAL_KEYS=""

# =============================================================================
# PROXY CONFIGURATION (Optional)
# =============================================================================
PROXY_ENABLED=false
PROXY_URL=""

# =============================================================================
# PERFORMANCE MODE
# Options: stealth (conservative), balanced (default), apex (aggressive)
# =============================================================================
PEACOCK_PERF_MODE=balanced

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable web chat UI (accessible at /chat)
CHAT_UI_ENABLED=false

# Enable debug logging
PEACOCK_DEBUG=false

# Enable verbose output
PEACOCK_VERBOSE=false

# =============================================================================
# SECURITY (Optional)
# =============================================================================
# API key for authenticating requests to this server
# If set, clients must include "X-API-Key" header
# API_KEY="your-secret-api-key-here"

# Allowed origins for CORS (comma-separated)
# CORS_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"

# =============================================================================
# DATABASE
# =============================================================================
# SQLite database path (relative to app directory)
DATABASE_PATH=peacock.db

# =============================================================================
# LOGGING
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/peacock.log
